{
  "name": "embed-dossier-mstr-react",
  "version": "2.0.0",
  "description": "A production-ready React library for embedding MicroStrategy Dossiers, Reports, and Bot Consumption pages with full TypeScript support.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --format cjs --dts --external react --external react-dom --clean",
    "dev": "tsup src/index.ts --format esm --format cjs --watch --dts --external react --external react-dom",
    "lint": "eslint \"src/**/*.ts*\"",
    "lint:fix": "eslint \"src/**/*.ts*\" --fix",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist && rm -rf coverage",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "14.2.0",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.0.6",
    "@vitest/ui": "3.0.6",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "5.5.4",
    "vite": "^8.0.8",
    "vitest": "^3.0.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ibrairsyad17/embed-dossier-mstr.git",
    "directory": "packages/embed-dossier-mstr-react"
  },
  "homepage": "https://github.com/Ibrairsyad17/embed-dossier-mstr#readme",
  "bugs": {
    "url": "https://github.com/Ibrairsyad17/embed-dossier-mstr/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mstr",
    "microstrategy",
    "react",
    "dossier",
    "embed",
    "sdk",
    "api",
    "typescript",
    "business-intelligence",
    "bi",
    "dashboard",
    "analytics",
    "embedding"
  ]
}
